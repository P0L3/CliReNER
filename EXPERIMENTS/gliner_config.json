{
    "training_parameters": {
        "learning_rate": 5e-6,
        "weight_decay": 0.01,
        "others_lr": 1e-5,
        "others_weight_decay": 0.01,
        "lr_scheduler_type": "linear",
        "warmup_ratio": 0.1,
        "per_device_train_batch_size": 8,
        "per_device_eval_batch_size": 8,
        "focal_loss_alpha": 0.75,
        "focal_loss_gamma": 2,
        "save_steps": 100,
        "save_total_limit": 10,
        "dataloader_num_workers": 0,
        "use_cpu": false,
        "report_to": "none",
        "eval_strategy": "steps",
        
        "calculate_epochs_from_steps": true,
        "target_steps": 4000
    }
}